    "inputSchema": {
      "type": "object",
      "properties": {
        "spreadsheet_id": { "type": "string", "description": "The ID of the spreadsheet (found in the URL)." },
        "range": { "type": "string", "description": "A1 notation range (e.g. 'Sheet1!A1:D10')." }
      },
      "required": ["spreadsheet_id", "range"]
    }
  },
